rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAttemptOwner(attemptId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/userAttempts/$(attemptId)).data.userId == request.auth.uid;
    }

    // USERS
    match /users/{userId} {
      allow read: if true;

      allow create: if true;

      // allow updating own profile
      allow update: if isOwner(userId);

      // allow deletion if signed in (lenient)
      allow delete: if true;
    }

    // QUESTIONS
    match /questions/{questionId} {
      allow read: if true;

      // any authenticated user can manage questions
      allow create, update, delete: if isSignedIn();
    }

    // QUIZZES
    match /quizzes/{quizId} {
      allow read: if true;

      // allow any authenticated user to manage quizzes
      allow create, update, delete: if isSignedIn();
    }

    // COURSES
    match /courses/{courseId} {
      allow read: if true;

      allow create, update, delete: if isSignedIn();
    }

    // DISCUSSIONS
    match /questionDiscussions/{discussionId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // FEEDBACK ENTRIES
    match /feedbackEntries/{feedbackId} {
      // lenient in-app feedback collection; dev mode UI still gates review features
      allow read, create, update, delete: if true;
    }

    // ADMIN NOTES
    match /adminNotes/{noteId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // USER ATTEMPTS
    match /userAttempts/{attemptId} {

      // attempts visible for analytics/debug
      allow read: if true;

      // users create attempts tied to their uid
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      // only attempt owner can update it
      allow update: if isAttemptOwner(attemptId);

      // allow deletion if signed in (lenient)
      allow delete: if isSignedIn();

      // ATTEMPT ANSWERS
      match /answers/{answerId} {
        allow read: if true;

        allow create: if isAttemptOwner(attemptId) &&
          request.resource.data.userId == request.auth.uid;

        allow update: if isAttemptOwner(attemptId);

        allow delete: if isSignedIn();
      }
    }
  }
}
